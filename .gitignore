# --- privacy: personal home data never enters git ---
/private-home-inputs/
# real-home trace DATA (room rects/labels + feature coords derived from the
# private plan). The tracing TOOLING (scripts/trace/*.mjs) is committed; the
# data it produces is not.
/scripts/trace/*.json

# --- local CC0 asset cache (downloaded by scripts/fetch-assets.ts) ---
/asset-cache/

# --- local app data (scenes, variants, job records written by the sidecar) ---
/.homecanvas/

# demo video: build artifacts stay local (final MP4 is committed under docs/)
/demo-video/out/
# real penthouse screen-grabs + the penthouse cut never leave the machine
/demo-video/public/captures/
/demo-video/**/homecanvas-penthouse.mp4

node_modules/
dist/
# Electron build outputs (esbuild bundles + electron-builder installers)
dist-electron/
release/
coverage/
*.local
.env
.env.*
.DS_Store
*.log
.gstack/

# landing-page local screenshots
/landing/preview-*.png

# Local Netlify folder
.netlify
