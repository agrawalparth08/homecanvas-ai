{
  "name": "homecanvas-demo-video",
  "version": "1.0.0",
  "private": true,
  "description": "Storyboard-driven product demo video for HomeCanvas AI (Remotion + local macOS TTS)",
  "scripts": {
    "narration": "node scripts/generate-narration.mjs",
    "captures": "node scripts/scan-captures.mjs",
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts HomeCanvasDemo out/homecanvas-demo.mp4 --codec=h264",
    "render:penthouse": "node scripts/scan-captures.mjs && remotion render src/index.ts HomeCanvasDemo out/homecanvas-penthouse.mp4 --codec=h264",
    "still": "remotion still src/index.ts HomeCanvasDemo"
  },
  "dependencies": {
    "@remotion/cli": "4.0.246",
    "@remotion/google-fonts": "4.0.246",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.246"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "typescript": "5.6.3"
  }
}
